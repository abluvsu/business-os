# BusinessOS Server Environment Variables

# OpenAI for Brain Interface
OPENAI_API_KEY="sk-..."

# Meta / Instagram Graph API
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_REDIRECT_URI="http://127.0.0.1:4000/api/connectors/instagram/callback"

# Google Workspace / Gmail API
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://127.0.0.1:4000/api/connectors/gmail/callback"
